ATTR \"General purpose attribute\" lines:20"

	ATTRIBUTE <vizGrayscaleMode>
	VALUE "EXPR val:0"

	ATTRIBUTE <General purpose attribute>
	VALUE ""

	ATTRIBUTE <HlpTxt>
	VALUE "The relation 'has Attribute' is used to specify which attributes an entity or a relation has. The sma"
	      "ll dot at the start of the relation shows the \"owner\" of the attribute."

	ATTRIBUTE <vizDirection>
	VALUE "EXPR val:\"no\""


RELATION <Links (ER)>
	FROM <Staff member> : <Entity (ER)>
	TO <is a> : <Relation (ER)>

	ATTRIBUTE <GraphRep>
	VALUE "GRAPHREP

#-- COLOR DEFINITIONS --
SET fontcolor:(\"black\")
SET colBrd:(\"black\")
SET colFFm:(\"black\")

# Based on the participation draw a different line
AVAL p:\"Participation\"
IF (p = \"Total participation\") {
  PEN w:0.1cm color:(colBrd)
  EDGE 
  PEN w:0.05cm color:white
  EDGE 
} ELSE {
  PEN color:(colBrd)
  EDGE
}
PEN color:(colBrd)
FILL color:(colFFm)

START

AVAL set-default:\"yes\" showdir:\"vizDirection\"
IF (showdir = \"yes\") {
  FILL color:(linecol)
  ELLIPSE x:0.0cm y:0.0cm rx:0.05cm ry:0.05cm
}

# Find out which notation to visualize
AVAL nota:\"Used Notation\" # Chen-Notation @ MC-Notation @ Min,Max-Notation @ None
IF (nota = \"Chen-Notation\") {
  AVAL nv:\"Chen-Notation\"
} ELSIF (nota = \"MC-Notation\") {
  AVAL nv:\"MC-Notation\"
} ELSIF (nota = \"Min,Max-Notation\") {
  AVAL nmin:\"Min\"
  AVAL nmax:\"Max\"
  IF (nmin = \"\" AND nmax = \"\") {
    SET nv:(\"\")
  } ELSE {
    SET nv:(\"(\" + nmin + \",\" + nmax + \")\")
  }
} ELSIF (nota = \"All\") {
  AVAL ch:\"Chen-Notation\"
  AVAL mc:\"MC-Notation\"
  AVAL nmin:\"Min\"
  AVAL nmax:\"Max\"
  SET nv:(ch + \" ; \" + mc + \" (\" + nmin + \",\" + nmax + \")\")
}

# Visualize the value (if apropriate)
MIDDLE
IF (nota <> \"None\" AND nv <> \"\") {
  TEXT (nv) x:0.1cm y:-0.05cm w:l h:b
}

# If directed or targeting an Associative entity, then draw an arrow
END
AVAL dir:\"Directed\"
IF (dir = \"yes\") {
  POLYGON 3
      x1:-0.3cm y1:-0.1cm
      x2:0.0cm y2:0.0cm
      x3:-0.3cm y3:0.1cm
}"

	ATTRIBUTE <AttrRep>
	VALUE "NOTEBOOK

